# TreasureFlow Admin — environment
# Fase 1 corre con datos mock. Para usar el backend real, define lo siguiente:

# Raíz del API Gateway, sin / final. Ej: http://localhost:3000
VITE_GATEWAY_URL=

# "false" usa los repositorios contra la API; "true" (o vacío) usa datos mock.
VITE_USE_MOCKS=true

# El acceso de admin lo decide el backend (users.is_admin). No hay whitelist de
# correos aquí: inicias sesión con tu cuenta normal marcada como admin en la BD.
